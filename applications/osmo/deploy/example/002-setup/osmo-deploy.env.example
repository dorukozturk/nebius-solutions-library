# OSMO deploy config (nip.io + env vars path)
# Copy to osmo-deploy.env and fill in. Scripts that source defaults.sh will load this automatically.
#
# Hostname for OSMO UI/API. KEYCLOAK_HOSTNAME is auto-set to auth-<this value>.
# Leave empty to auto-detect from the NGINX Ingress LoadBalancer IP (e.g. osmo.89-169-123-177.nip.io).
# If set to a nip.io hostname that doesn't match the current LB IP, it is auto-corrected when you run 03b/04.
export OSMO_INGRESS_HOSTNAME=""

# Nebius SSO (recommended: one place for auth)
# Leave NEBIUS_SSO_CLIENT_ID and NEBIUS_SSO_CLIENT_SECRET empty to auto-create via npc (04-deploy with npc in PATH and NEBIUS_PROJECT_ID set, e.g. source 000-prerequisites/nebius-env-init.sh).
export NEBIUS_SSO_ENABLED="true"
export NEBIUS_SSO_ISSUER_URL="https://auth.nebius.com"
export NEBIUS_SSO_CLIENT_ID=""
export NEBIUS_SSO_CLIENT_SECRET=""

# PostgreSQL password for OSMO (if not using MysteryBox / TF_VAR_postgresql_mysterybox_secret_id)
export OSMO_POSTGRESQL_PASSWORD=""

# Social IdPs (optional): add Google, GitHub, or Microsoft login. Create OAuth apps in each provider and set
# redirect URI to https://<AUTH_DOMAIN>/realms/osmo/broker/<alias>/endpoint (alias: google, github, microsoft).
# export GOOGLE_SSO_CLIENT_ID=""
# export GOOGLE_SSO_CLIENT_SECRET=""
# export GITHUB_SSO_CLIENT_ID=""
# export GITHUB_SSO_CLIENT_SECRET=""
# export MICROSOFT_SSO_CLIENT_ID=""
# export MICROSOFT_SSO_CLIENT_SECRET=""
# export MICROSOFT_SSO_TENANT="common"   # Azure AD tenant (common = multi-tenant)

# Skip PostgreSQL connection test in 04 (use while fixing cluster->DB network; re-run 04 without this to verify)
# export SKIP_POSTGRES_CONNECTION_TEST="0"
